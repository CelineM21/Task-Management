<div class="auth-page">
  <div class="auth-card">
    <div class="auth-logo">
      <div class="auth-logo-icon">
        <svg viewBox="0 0 32 32" fill="none"><path d="M8 11h16M8 16h10M8 21h13" stroke="#fff" stroke-width="2.5" stroke-linecap="round"/><circle cx="24" cy="21" r="3.5" fill="#10b981"/></svg>
      </div>
      <div class="auth-brand">TaskFlow</div>
      <div class="auth-subtitle">Create your account</div>
    </div>

    <% if (errors && errors.length > 0) { %>
      <div class="alert alert-danger">
        <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
        <ul style="margin:0;padding-left:1rem;">
          <% errors.forEach(e => { %><li><%= e.msg %></li><% }); %>
        </ul>
      </div>
    <% } %>

    <form action="/auth/register" method="POST">
      <div class="form-group">
        <label class="form-label" for="name">Full name</label>
        <input type="text" class="form-control" id="name" name="name" placeholder="Jane Doe" required>
      </div>
      <div class="form-group">
        <label class="form-label" for="email">Email address</label>
        <input type="email" class="form-control" id="email" name="email" placeholder="you@example.com" required>
      </div>
      <div class="form-group">
        <label class="form-label" for="password">Password</label>
        <input type="password" class="form-control" id="password" name="password" placeholder="Min. 6 characters" required>
        <div class="form-hint">The very first registered user becomes the admin.</div>
      </div>
      <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;padding:.7rem;">Create Account</button>
    </form>

    <div class="auth-divider">Already have an account? <a href="/auth/login" class="auth-link">Sign in</a></div>
  </div>
</div>
