<div class="page-header">
  <div>
    <h1 class="page-title">Projects</h1>
    <p class="page-subtitle">
      <% if (locals.currentUser.role === 'user') { %>Your assigned projects<% } else { %>All projects<% } %>
    </p>
  </div>
  <% if (locals.currentUser.role === 'admin' || locals.currentUser.role === 'manager') { %>
  <a href="/projects/new" class="btn btn-primary">
    <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd"/></svg>
    New Project
  </a>
  <% } %>
</div>

<% if (!projects || projects.length === 0) { %>
<div class="table-wrapper">
  <div class="empty-state">
    <svg viewBox="0 0 20 20" fill="currentColor"><path d="M7 3a1 1 0 000 2h6a1 1 0 100-2H7zM4 7a1 1 0 011-1h10a1 1 0 110 2H5a1 1 0 01-1-1zM2 11a2 2 0 012-2h12a2 2 0 012 2v4a2 2 0 01-2 2H4a2 2 0 01-2-2v-4z"/></svg>
    <p>No projects found.<% if (locals.currentUser.role === 'user') { %> You haven't been assigned to any projects yet.<% } %></p>
  </div>
</div>
<% } else { %>
<div class="table-wrapper">
  <table>
    <thead>
      <tr>
        <th>Project Name</th>
        <th>Status</th>
        <th>Members</th>
        <th>Created</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% projects.forEach(project => { %>
      <tr>
        <td>
          <a href="/projects/<%= project._id %>" style="font-weight:600;color:var(--primary);text-decoration:none;">
            <%= project.name %>
          </a>
          <% if (project.description) { %>
          <div style="font-size:.78rem;color:var(--gray-400);margin-top:.1rem;"><%= project.description.substring(0,60) %><%= project.description.length > 60 ? '...' : '' %></div>
          <% } %>
        </td>
        <td>
          <span class="badge badge-<%= project.status %>"><%= project.status %></span>
        </td>
        <td>
          <% const members = project.members.filter(Boolean); %>
          <% if (members.length) { %>
            <% members.slice(0,3).forEach(m => { %><span class="member-chip"><%= m.name %></span><% }); %>
            <% if (members.length > 3) { %><span style="font-size:.78rem;color:var(--gray-400);">+<%= members.length - 3 %> more</span><% } %>
          <% } else { %>
            <span style="color:var(--gray-400);font-size:.85rem;">No members</span>
          <% } %>
        </td>
        <td style="color:var(--gray-500);font-size:.82rem;"><%= project.createdAt ? new Date(project.createdAt).toLocaleDateString() : '—' %></td>
        <td>
          <div class="actions-cell">
            <a href="/projects/<%= project._id %>" class="btn btn-sm btn-secondary" title="View">
              <svg viewBox="0 0 20 20" fill="currentColor"><path d="M10 12a2 2 0 100-4 2 2 0 000 4z"/><path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10z" clip-rule="evenodd"/></svg>
              View
            </a>
            <% if (locals.currentUser.role === 'admin' || locals.currentUser.role === 'manager') { %>
            <a href="/projects/<%= project._id %>/edit" class="btn btn-sm btn-warning" title="Edit">
              <svg viewBox="0 0 20 20" fill="currentColor"><path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z"/></svg>
              Edit
            </a>
            <% } %>
            <% if (locals.currentUser.role === 'admin') { %>
            <form action="/projects/<%= project._id %>?_method=DELETE" method="POST" class="d-inline" onsubmit="return confirm('Delete this project and all its tasks?')">
              <button class="btn btn-sm btn-danger" title="Delete">
                <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
                Delete
              </button>
            </form>
            <% } %>
          </div>
        </td>
      </tr>
      <% }); %>
    </tbody>
  </table>
</div>
<% } %>
