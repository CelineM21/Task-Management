<div class="page-header">
  <div>
    <h1 class="page-title">Tasks</h1>
    <p class="page-subtitle">
      <% if (locals.currentUser.role === 'user') { %>Your assigned tasks<% } else { %>All tasks<% } %>
    </p>
  </div>
  <a href="/tasks/new" class="btn btn-primary">
    <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd"/></svg>
    New Task
  </a>
</div>

<% if (!tasks || tasks.length === 0) { %>
<div class="table-wrapper">
  <div class="empty-state">
    <svg viewBox="0 0 20 20" fill="currentColor"><path d="M9 2a1 1 0 000 2h2a1 1 0 100-2H9z"/><path fill-rule="evenodd" d="M4 5a2 2 0 012-2 3 3 0 003 3h2a3 3 0 003-3 2 2 0 012 2v11a2 2 0 01-2 2H6a2 2 0 01-2-2V5z" clip-rule="evenodd"/></svg>
    <p>No tasks found.<% if (locals.currentUser.role === 'user') { %> No tasks have been assigned to you yet.<% } %></p>
  </div>
</div>
<% } else { %>
<div class="table-wrapper">
  <table>
    <thead>
      <tr>
        <th>Task</th>
        <th>Status</th>
        <th>Priority</th>
        <th>Assigned To</th>
        <th>Project</th>
        <th>Due Date</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% tasks.forEach(task => { %>
      <tr>
        <td>
          <a href="/tasks/<%= task._id %>" style="font-weight:600;color:var(--primary);text-decoration:none;"><%= task.title %></a>
          <% if (task.description) { %>
          <div style="font-size:.78rem;color:var(--gray-400);margin-top:.1rem;"><%= task.description.substring(0,50) %><%= task.description.length > 50 ? '...' : '' %></div>
          <% } %>
        </td>
        <td><span class="badge badge-<%= task.status %>"><%= task.status %></span></td>
        <td><span class="badge badge-priority-<%= task.priority %>"><%= task.priority %></span></td>
        <td>
          <% if (task.assignedUser) { %>
          <div style="display:flex;align-items:center;gap:.5rem;">
            <div class="user-avatar" style="width:26px;height:26px;font-size:.7rem;"><%= task.assignedUser.name.charAt(0).toUpperCase() %></div>
            <%= task.assignedUser.name %>
          </div>
          <% } else { %>—<% } %>
        </td>
        <td>
          <% if (task.project) { %>
          <a href="/projects/<%= task.project._id %>" style="color:var(--gray-600);text-decoration:none;"><%= task.project.name %></a>
          <% } else { %>—<% } %>
        </td>
        <td style="font-size:.82rem;color:var(--gray-500);">
          <% if (task.dueDate) { %>
            <%= new Date(task.dueDate).toLocaleDateString() %>
          <% } else { %>—<% } %>
        </td>
        <td>
          <div class="actions-cell">
            <a href="/tasks/<%= task._id %>" class="btn btn-sm btn-secondary" title="View">
              <svg viewBox="0 0 20 20" fill="currentColor"><path d="M10 12a2 2 0 100-4 2 2 0 000 4z"/><path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10z" clip-rule="evenodd"/></svg>
            </a>
            <%
              const isOwner = task.assignedUser && task.assignedUser._id.toString() === locals.currentUser.id;
              const canEdit = locals.currentUser.role !== 'user' || isOwner;
            %>
            <% if (canEdit) { %>
            <a href="/tasks/<%= task._id %>/edit" class="btn btn-sm btn-warning" title="Edit">
              <svg viewBox="0 0 20 20" fill="currentColor"><path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z"/></svg>
            </a>
            <% } %>
            <% if (locals.currentUser.role === 'admin' || locals.currentUser.role === 'manager') { %>
            <form action="/tasks/<%= task._id %>?_method=DELETE" method="POST" onsubmit="return confirm('Delete this task?')">
              <button class="btn btn-sm btn-danger" title="Delete">
                <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
              </button>
            </form>
            <% } %>
          </div>
        </td>
      </tr>
      <% }); %>
    </tbody>
  </table>
</div>
<% } %>
